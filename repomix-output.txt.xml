            buses_with_nuclear = n.buses.loc[nuclear_gens_bus]
            buses_with_nuclear_ind = n.buses.loc[nuclear_gens_bus].index

            # nn.add("Carrier", "nuclear electricity")
            # nn.add("Carrier", "pink H2")

            n.madd(
                "Bus",
