    agg = agg[(agg.carrier == carrier)]
    agg.value = agg.value.apply(int)
    if node_id == "all":
        agg = agg.groupby("tech").sum().reset_index()
    else:
        agg = agg[agg.node_id.str.contains(node_id)].groupby("tech").sum().reset_index()
    return agg


