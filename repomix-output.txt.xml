    gen_caps = (
        n.generators.groupby(n.generators.carrier.str.strip().str.lower())
        .p_nom.sum()
        .div(1e3)
        .rename("Generators [GW]")
    )
    sto_caps = (
        n.storage_units.groupby(n.storage_units.carrier.str.strip().str.lower())
        .p_nom.sum()
        .div(1e3)
        .rename("StorageUnits [GW]")
